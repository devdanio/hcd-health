enum EventSource {
  GHL
  // WEBSITE
  // POSTHOG
  // SHOPIFY
}

model Event {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  eventSource EventSource

  type     EventType
  data Json

  createdAt DateTime @default(now())

  @@index([contactId])
}

enum EventType {
  PAGE_VIEW
  CONTACT_CREATED
  CALL_RECEIVED
  CHAT
  FB_FORM_SUBMISSION
  SCHEDULED_CALL
  // Used for data imports where we have attribution data but no events
  UNKNOWN
}

// Services
model Service {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers    Provider[]
  appointments Appointment[]

  @@index([companyId])
}

enum PaymentStatus {
  pending
  posted
  failed
}
model Payments{
  id String @id @default(cuid())
  externalId String @unique
  amountInCents Int
  posted_date DateTime
  status PaymentStatus
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  

  @@index([contactId])
}



// Providers
model Provider {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@index([companyId])
  @@index([serviceId])
}

// Appointments
model Appointment {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dateOfService DateTime
  service       String?
  serviceId     String?
  serviceRel    Service?  @relation(fields: [serviceId], references: [id])
  providerId    String?
  provider      Provider? @relation(fields: [providerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  procedures AppointmentProcedure[]

}

// Appointment Procedures - Revenue tracking
model AppointmentProcedure {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  procedureCode String
  chargeAmount  Float

  // High level grouping of insurance
  caseType String?
  // Specific insurance pan that is paying
  payerName String?

  chargeDate DateTime?

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@index([appointmentId, procedureCode])
}

