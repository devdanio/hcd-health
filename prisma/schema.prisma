generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model CityLatLng{
  city String
  state String
  latitude Float
  longitude Float

  @@unique([city, state])
}

model LeadCalculator {
  id                String   @id @default(cuid())
  name              String
  email             String
  revenue           Float
  patients          Int
  newPatients       Int
  avgVisits         Float
  marketingCosts    Float
  directCareCosts   Float
  overheadCosts     Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Companies - Multi-tenant root
model Company {
  id           String   @id @default(cuid())
  name         String
  domain       String
  companyBrief String?
  apiKey       String   @unique
  ehr          EhrType?
  address      String?

  // Google Ads OAuth (encrypted tokens stored directly)
  googleAdsAccessToken       String?
  googleAdsRefreshToken      String?
  googleAdsTokenExpiresAt    DateTime?
  googleAdsCustomerId        String?
  googleAdsAccountName       String?
  googleAdsCurrencyCode      String?
  googleAdsTimeZone          String?
  googleAdsConnectedAt       DateTime?
  googleAdsAccountSelectedAt DateTime?
  googleAdsLastSyncedAt      DateTime?
  googleAdsLastError         String?
  googleAdsLastErrorAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts     Contact[]
  // sessions     Session[]
  services     Service[]
  providers    Provider[]
  appointments Appointment[]
  oauthStates  OAuthState[]
  cmsPages     CmsPage[]
  @@index([apiKey])
}

enum EhrType {
  unified_practice
  chirotouch
  ghl
}

// Deprecated - use Event instead
model GHLEvent{
  id String @id @default(cuid())
  companyId String
  data      Json
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // First time we ever saw this contact, usually maps to the EHR's createdAt if we're doing a backfill
  firstSeenAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email     String?
  phone     String?
  fullName  String?
  firstName String?
  lastName  String?
  gender    String?
  dateOfBirth DateTime?

  externalIds ExternalId[]
  address1 String?
  address2 String?
  zip String?
  city String?
  state String?


  payments Payments[]
  appointments Appointment[]
  // sessions Session[]
  events Event[]

  @@index([companyId, email])
  @@index([companyId, phone])
  @@index([companyId])
}


enum ExternalIdSource {
  POSTHOG
  GHL
  CHIROTOUCH
  SHOPIFY
  UNIFIED_PRACTICE
  JASMINE
}

model ExternalId {
  contactId String
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  externalId String @unique
  source ExternalIdSource
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
  @@index([contactId, externalId])
  @@index([source, externalId])
  @@index([source, contactId])
}


