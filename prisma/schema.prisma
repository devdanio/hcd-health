generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Call {
  id         String   @id
  email      String?
  phone      String?
  user_id    String?
  timestamp  DateTime @default(now())
  duration   Int?
  status     String?
  properties Json?

  @@index([email])
  @@index([phone])
  @@index([user_id])
}

model CanonicalUser {
  id            String         @id
  created_at    DateTime       @default(now())
  updated_at    DateTime
  emails        String[]
  phones        String[]
  user_ids      String[]
  anonymous_ids String[]
  first_name    String?
  last_name     String?
  Identifier    Identifier[]
  UnifiedEvent  UnifiedEvent[]
}

model Identifier {
  id                String         @id
  type              IdentifierType
  value             String
  canonical_user_id String
  created_at        DateTime       @default(now())
  CanonicalUser     CanonicalUser  @relation(fields: [canonical_user_id], references: [id])

  @@unique([type, value])
  @@index([canonical_user_id])
  @@index([type, value])
}

model Page {
  id           String   @id
  anonymous_id String?
  user_id      String?
  timestamp    DateTime @default(now())
  url          String?
  title        String?
  properties   Json?

  @@index([anonymous_id])
  @@index([user_id])
}

model Track {
  id           String   @id
  anonymous_id String?
  email        String?
  user_id      String?
  timestamp    DateTime @default(now())
  event        String?
  properties   Json?

  @@index([anonymous_id])
  @@index([email])
  @@index([user_id])
}

model UnifiedEvent {
  id                String        @id
  canonical_user_id String
  source_table      SourceTable
  source_id         String
  event_type        String?
  timestamp         DateTime
  properties        Json?
  created_at        DateTime      @default(now())
  CanonicalUser     CanonicalUser @relation(fields: [canonical_user_id], references: [id])

  @@unique([source_table, source_id])
  @@index([canonical_user_id])
  @@index([source_table, source_id])
  @@index([timestamp])
}

enum IdentifierType {
  EMAIL
  PHONE
  USER_ID
  ANONYMOUS_ID
}

enum SourceTable {
  PAGES
  TRACKS
  CALLS
}
