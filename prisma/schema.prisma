generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model CityLatLng{
  city String
  state String
  latitude Float
  longitude Float

  @@unique([city, state])
}

model LeadCalculator {
  id                String   @id @default(cuid())
  name              String
  email             String
  revenue           Float
  patients          Int
  newPatients       Int
  avgVisits         Float
  marketingCosts    Float
  directCareCosts   Float
  overheadCosts     Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Companies - Multi-tenant root
model Company {
  id           String   @id @default(cuid())
  name         String
  domain       String
  companyBrief String?
  apiKey       String   @unique
  ehr          EhrType?
  address      String?

  // Google Ads OAuth (encrypted tokens stored directly)
  googleAdsAccessToken       String?
  googleAdsRefreshToken      String?
  googleAdsTokenExpiresAt    DateTime?
  googleAdsCustomerId        String?
  googleAdsAccountName       String?
  googleAdsCurrencyCode      String?
  googleAdsTimeZone          String?
  googleAdsConnectedAt       DateTime?
  googleAdsAccountSelectedAt DateTime?
  googleAdsLastSyncedAt      DateTime?
  googleAdsLastError         String?
  googleAdsLastErrorAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts     Contact[]
  sessions     Session[]
  events       Event[]
  services     Service[]
  providers    Provider[]
  appointments Appointment[]
  oauthStates  OAuthState[]
  cmsPages     CmsPage[]
  ghlContacts  GhlContact[]
  payments Payments[]
  @@index([apiKey])
}

enum EhrType {
  unified_practice
  chirotouch
  ghl
}

model GHLEvent{
  id String @id @default(cuid())
  companyId String
  data      Json
  createdAt DateTime @default(now())
}

// Contacts - Unified visitor/patient identity
model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email     String?
  phone     String?
  fullName  String?
  firstName String?
  lastName  String?
  gender    String?
  dateOfBirth DateTime?

  externalIds ExternalId[]
  address1 String?
  address2 String?
  zip String?
  city String?
  state String?


  payments Payments[]
  appointments Appointment[]


  ghlContactId String?     @unique
  ghlContact   GhlContact? @relation(fields: [ghlContactId], references: [id])

  chirotouchAccountId String? @unique

  sessions Session[]
  contactEvents ContactEvent[]

  @@index([companyId, email])
  @@index([companyId, phone])
  @@index([companyId, ghlContactId])
  @@index([companyId])
  @@index([ghlContactId])
  @@index([chirotouchAccountId])
}

// Contact Events - Custom events associated with contacts
model ContactEvent {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  companyId String

  eventType String
  data      Json

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([companyId])
  @@index([eventType])
}

enum ExternalIdSource {
  POSTHOG
  GHL
  CHIROTOUCH
  SHOPIFY
  UNIFIED_PRACTICE
  JASMINE
}

model ExternalId {
  contactId String
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  externalId String @unique
  source String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
  @@index([contactId, externalId])
}

// GHL Contacts - External CRM sync
model GhlContact {
  id           String    @id
  locationId   String
  contactName  String?
  firstName    String?
  lastName     String?
  companyName  String?
  email        String?
  phone        String?
  dnd          Boolean   @default(false)
  type         String?
  source       String?
  assignedTo   String?
  city         String?
  state        String?
  postalCode   String?
  address1     String?
  dateAdded    DateTime
  dateUpdated  DateTime
  dateOfBirth  Json?
  tags         String[]
  country      String?
  website      String?
  timezone     String?
  lastActivity DateTime?
  customField  Json[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contact Contact?
}

// Sessions - Browser sessions with attribution
model Session {
  id               String  @id @default(cuid())
  browserSessionId String  @unique
  contactId        String
  contact          Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userAgent        String?
  ipAddress        String?
  screenResolution String?
  timezone         String?

  // Attribution stored as JSON (UTM params + click IDs)
  firstSessionAttribution Json
  lastSessionAttribution  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    Event[]
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  @@index([contactId])
  @@index([browserSessionId])
}

// Events - Tracking events (pageviews, conversions)
model Event {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type     EventType
  data Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([companyId, type])
  @@index([companyId])
  @@index([createdAt])
}

enum EventType {
  pageview
  conversion
  custom_event
}

// Services
model Service {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers    Provider[]
  appointments Appointment[]

  @@index([companyId])
}

enum PaymentStatus {
  pending
  posted
  failed
}
model Payments{
  id String @id @default(cuid())
  externalId String @unique
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  amount_in_cents Int
  posted_date DateTime
  status PaymentStatus
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([companyId])
  @@index([externalId])
}



// Providers
model Provider {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@index([companyId])
  @@index([serviceId])
}

// Appointments
model Appointment {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dateOfService DateTime
  service       String?
  serviceId     String?
  serviceRel    Service?  @relation(fields: [serviceId], references: [id])
  providerId    String?
  provider      Provider? @relation(fields: [providerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  procedures AppointmentProcedure[]

}

// Appointment Procedures - Revenue tracking
model AppointmentProcedure {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  procedureCode String
  chargeAmount  Float

  // High level grouping of insurance
  caseType String?
  // Specific insurance pan that is paying
  payerName String?

  chargeDate DateTime?

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@index([appointmentId, procedureCode])
}

